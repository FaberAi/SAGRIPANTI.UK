# Variabili per il deploy su box.sagripanti.uk (Hetzner).
# Copia questo file in `.env` sulla box e compila i valori:
#   cp .env.box.example .env
# NB: `.env` è in .gitignore — non verrà committato.

# --- Dominio / HTTPS ---
SITE_DOMAIN=box.sagripanti.uk
ACME_EMAIL=tu@sagripanti.uk

# --- Database Postgres (in Docker) ---
POSTGRES_USER=sagripanti
POSTGRES_PASSWORD=cambia-questa-password-robusta
POSTGRES_DB=sagripanti

# --- App ---
# Token condiviso per l'autenticazione (vedi src/lib/auth.ts).
AUTH_TOKEN=genera-un-token-lungo-e-casuale
# Secret per proteggere l'endpoint del cron /api/cron/bots.
CRON_SECRET=genera-un-altro-secret-casuale

# --- Telegram (opzionali: lascia vuoti se non usi le notifiche) ---
TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
