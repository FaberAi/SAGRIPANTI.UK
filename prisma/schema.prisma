generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int         @id @default(autoincrement())
  email        String      @unique
  passwordHash String
  name           String?
  isAdmin        Boolean     @default(false)
  active         Boolean     @default(true)
  // Chat ID Telegram per le notifiche dei segnali dei bot (null = non collegato).
  telegramChatId String?
  createdAt      DateTime    @default(now())
  portfolio      Portfolio?
  bots           BotConfig[]
}

model Portfolio {
  id        Int        @id @default(autoincrement())
  cash      Float      @default(100000)
  createdAt DateTime   @default(now())
  userId    Int        @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions Position[]
  trades    Trade[]
}

model Position {
  id          Int       @id @default(autoincrement())
  symbol      String
  quantity    Float
  avgPrice    Float
  portfolioId Int
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, symbol])
}

model Trade {
  id          Int       @id @default(autoincrement())
  symbol      String
  type        String    // "BUY" | "SELL"
  quantity    Float
  price       Float
  fee         Float
  total       Float
  source      String    @default("manual") // "manual" | "bot"
  botName     String?
  createdAt   DateTime  @default(now())
  portfolioId Int
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model BotConfig {
  id         Int       @id @default(autoincrement())
  name       String
  symbol     String
  strategy   String    // "MA_CROSSOVER" | "RSI_REVERSION" | "MACD_SIGNAL"
  params     String    // JSON string
  active     Boolean   @default(false)
  lastRunAt  DateTime?
  lastSignal String?   // ultimo segnale agito: BUY | SELL | HOLD
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  userId     Int
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs       BotRun[]

  @@index([userId])
}

model BotRun {
  id        Int       @id @default(autoincrement())
  botId     Int
  bot       BotConfig @relation(fields: [botId], references: [id], onDelete: Cascade)
  action    String    // BUY | SELL | HOLD | SKIP | ERROR
  reason    String    // perché la strategia ha prodotto quel segnale
  message   String    // esito leggibile dell'esecuzione
  price     Float?
  quantity  Float?
  createdAt DateTime  @default(now())

  @@index([botId, createdAt])
}
